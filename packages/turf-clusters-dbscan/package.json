{
  "name": "@turf/clusters-dbscan",
  "version": "7.3.5",
  "description": "Takes a set of points and partition them into clusters according to DBSCAN's data clustering algorithm.",
  "author": "Turf Authors",
  "contributors": [
    "Lukasz <@uhho>",
    "Denis Carriere <@DenisCarriere>",
    "Stefano Borghi <@stebogit>"
  ],
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/Turfjs/turf/issues"
  },
  "homepage": "https://github.com/Turfjs/turf",
  "repository": {
    "type": "git",
    "url": "git://github.com/Turfjs/turf.git"
  },
  "funding": "https://opencollective.com/turf",
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "turf",
    "geojson",
    "cluster",
    "clusters",
    "clustering",
    "density",
    "dbscan"
  ],
  "type": "module",
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/esm/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "import": {
        "types": "./dist/esm/index.d.ts",
        "default": "./dist/esm/index.js"
      },
      "require": {
        "types": "./dist/cjs/index.d.ts",
        "default": "./dist/cjs/index.js"
      }
    }
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "scripts": {
    "bench": "tsx bench.ts",
    "build": "tsc -b",
    "prepack": "tsc -b tsconfig.cjs.json",
    "test": "pnpm run /test:.*/",
    "test:tape": "tsx test.ts",
    "test:types": "tsc --project tsconfig.types.json"
  },
  "devDependencies": {
    "@turf/centroid": "workspace:*",
    "@turf/clusters": "workspace:*",
    "@types/benchmark": "catalog:",
    "@types/rbush": "^3.0.4",
    "@types/tape": "catalog:",
    "benchmark": "catalog:",
    "chromatism": "^3.0.0",
    "concaveman": "^1.2.1",
    "load-json-file": "^7.0.1",
    "tape": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "write-json-file": "^6.0.0"
  },
  "dependencies": {
    "@turf/clone": "workspace:*",
    "@turf/distance": "workspace:*",
    "@turf/helpers": "workspace:*",
    "@turf/meta": "workspace:*",
    "@types/geojson": "catalog:",
    "rbush": "^3.0.1",
    "tslib": "catalog:"
  }
}
