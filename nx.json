{
  "analytics": false,
  "tui": {
    "enabled": false
  },
  "namedInputs": {
    "default": [
      "{workspaceRoot}/pnpm-lock.yaml",
      "{workspaceRoot}/tsconfig.shared.json",
      "{projectRoot}/package.json",
      "{projectRoot}/tsconfig.json"
    ],
    "sources": ["{projectRoot}/index.ts", "{projectRoot}/lib/**"]
  },
  "targetDefaults": {
    "test": {
      "inputs": [
        "default",
        "sources",
        "{projectRoot}/test.ts",
        "{projectRoot}/test/**",
        "{projectRoot}/types.ts"
      ],
      "dependsOn": [],
      "cache": true
    }
  }
}
